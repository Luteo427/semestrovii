<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UI/LoadingStyles.uss?fileID=7433441132597879392&amp;guid=7275f2fff913118409d792bc7012c392&amp;type=3#LoadingStyles"/>
    <ui:VisualElement name="root" style="flex-grow: 1; flex-direction: column; flex-basis: auto; background-color: rgb(0, 0, 0);">
        <ui:VisualElement name="BottomRightAnchor" style="flex-grow: 1; flex-direction: row; align-content: auto; align-self: auto; justify-content: center; align-items: center; position: absolute; left: auto; top: auto; bottom: 20px; right: 20px;">
            <ui:Label text="Текст" name="LoadingText" style="background-color: rgb(255, 255, 255); height: 38px; width: 205px; position: relative; top: auto; left: auto; align-self: auto; right: auto; bottom: auto;"/>
            <ui:VisualElement name="LoadingIcon" style="flex-grow: 0; right: auto; bottom: auto; flex-shrink: 0; width: 64px; height: 64px; background-color: rgb(255, 255, 255); align-self: auto; justify-content: flex-start; align-items: stretch; left: auto; top: auto; position: relative;"/>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
